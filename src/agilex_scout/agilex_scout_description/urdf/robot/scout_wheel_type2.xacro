<?xml version="1.0"?>

<robot xmlns:xacro="http://ros.org/wiki/xacro" name="scout_v2">

	<xacro:macro name="scout_wheel_type2" params="wheel_prefix x y z phi">

		<link name="${wheel_prefix}_wheel_link">
			<inertial>
				<mass value="8" />
				<origin xyz="0 0 0" />
				<inertia ixx="0.1171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.1171" />
			</inertial>
			<visual>
				<origin xyz="0 0 0" rpy="0 0 0" />
				<geometry>
					<mesh filename="file://$(find agilex_scout_description)/meshes/robot/wheel_type2.dae" />
				</geometry>
			</visual>
			<collision>
				<origin xyz="0 0 0" rpy="${pi/2} 0 0" />
				<geometry>
					<cylinder length="${wheel_length}" radius="${wheel_radius}" />
				</geometry>
				<surface>
					<contact>
						<ode>
							<min_depth>0.001</min_depth>
							<kp>1000000000.0</kp>
							<kd>0.0</kd>
						</ode>
					</contact>
					<friction>
						<ode>
							<mu>0.9</mu>
							<mu2>0.7</mu2>
							<fdir1>1 0 0</fdir1>
						</ode>
					</friction>
				</surface>
			</collision>
		</link>

		<!-- if gazebo is loaded, simulate the robot wheel rotations and broadcast the join states-->
		<xacro:if value="$(arg sim)">
			<joint name="${wheel_prefix}_wheel" type="continuous">
				<parent link="mobile_robot_base_link" />
				<child link="${wheel_prefix}_wheel_link" />
				<origin xyz="${x} ${y} ${z}" rpy="${phi} 0.0 0.0" />
				<axis xyz="0 1 0" rpy="0 0 0" />
				<dynamics damping="0.0" friction="20" />
			</joint>
		</xacro:if>

		<!-- if real robot is loaded, fixed wheels are used because no joint broadcaster is available -->
		<xacro:unless value="$(arg sim)">
			<joint name="${wheel_prefix}_wheel" type="fixed">
				<parent link="mobile_robot_base_link" />
				<child link="${wheel_prefix}_wheel_link" />
				<origin xyz="${x} ${y} ${z}" rpy="${phi} 0.0 0.0" />
				<axis xyz="0 1 0" rpy="0 0 0" />
			</joint>
		</xacro:unless>

	</xacro:macro>

</robot>